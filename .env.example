# Used by docker-compose.yml. Copy this file to .env and adjust the values
# before running `docker compose up`.

# Database
DB_NAME=task-manager
DB_PASSWORD=changeme

# Auth - generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=changeme
JWT_EXPIRES_IN=12h

# Frontend origin allowed to call the API
CORS_ORIGIN=http://localhost:3000

# Backend URL baked into the frontend build (must be reachable from the browser)
REACT_APP_BACKEND_URL=http://localhost:4000

# Host ports
BACKEND_PORT=4000
FRONTEND_PORT=3000
